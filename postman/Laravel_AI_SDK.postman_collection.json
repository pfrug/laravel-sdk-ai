{
	"info": {
		"name": "Laravel AI SDK",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url_sdk_ai",
			"value": "http://localhost:8000/api"
		},
		{
			"key": "auth_token",
			"value": ""
		},
		{
			"key": "conversation_id",
			"value": ""
		}
	],
	"item": [
		{
			"name": "00 — Auth",
			"item": [
				{
					"name": "Get Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"if (res.token) {",
									"    pm.collectionVariables.set('auth_token', res.token);",
									"    console.log('Token saved to collection variable');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/token",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["token"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"email\": \"test@example.com\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "01 — Introduction",
			"item": [
				{
					"name": "Basic Prompt",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/prompt",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "prompt"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"prompt\": \"Define 'Service Provider' in Laravel in 10 words.\"\n}"
						}
					}
				},
				{
					"name": "Prompt with Instructions",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/prompt",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "prompt"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"prompt\": \"What is middleware in Laravel?\",\n\t\"instructions\": \"Answer in one sentence only.\"\n}"
						}
					}
				},
				{
					"name": "Prompt with Provider Selection",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/prompt",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "prompt"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"prompt\": \"Name 3 Laravel design patterns in a bullet list.\",\n\t\"instructions\": \"Be brief. No explanations.\",\n\t\"provider\": \"gemini\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "02 — Agents",
			"item": [
				{
					"name": "Conversation — Start",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"const res = pm.response.json();",
									"if (res.conversation_id) {",
									"    pm.collectionVariables.set('conversation_id', res.conversation_id);",
									"    console.log('conversation_id saved: ' + res.conversation_id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/conversation",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "conversation"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"prompt\": \"Explicame en pocas palabras el ciclo de vida de un request en Laravel.\"\n}"
						}
					}
				},
				{
					"name": "Conversation — Continue",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/conversation",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "conversation"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"prompt\": \"Explicame brevemente dónde interviene el middleware en ese flujo.\",\n\t\"conversation_id\": \"{{conversation_id}}\"\n}"
						}
					}
				},
				{
					"name": "Structured Output",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{auth_token}}"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/structured",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "structured"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"prompt\": \"Evaluá este código: Route::get('/users', fn() => User::all());\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "03 — Streaming, Tools, Queue",
			"item": [
				{
					"name": "Streaming (SSE)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "text/event-stream"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/stream?prompt=Listá brevemente las novedades de Laravel 12.",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "stream"],
							"query": [
								{
									"key": "prompt",
									"value": "Listá brevemente las novedades de Laravel 12."
								}
							]
						}
					}
				},
				{
					"name": "Tools (Calculator)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/tools",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "tools"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"prompt\": \"Generá un número aleatorio entre 1 y 100.\"\n}"
						}
					}
				},
				{
					"name": "Queue",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/queue",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "queue"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"prompt\": \"Explicame brevemente la diferencia entre queues y events en Laravel.\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "04 — Image Generation",
			"item": [
				{
					"name": "Generate Image",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/image",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "image"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"prompt\": \"Un gato durmiendo sobre un teclado\",\n\t\"format\": \"landscape\",\n\t\"quality\": \"low\"\n}"
						}
					}
				},
				{
					"name": "Generate Image (Queue)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/image/queue",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "image", "queue"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"prompt\": \"Un gato durmiendo sobre un teclado\",\n\t\"format\": \"square\",\n\t\"quality\": \"low\"\n}"
						}
					}
				}
			]
		},
		{
			"name": "05 - Audio TTS y STT",
			"item": [
				{
					"name": "Text to Speech",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/audio/tts",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "audio", "tts"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"text\": \"Me encanta programar con Laravel.\",\n\t\"voice\": \"female\"\n}"
						}
					}
				},
				{
					"name": "Speech to Text",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/audio/stt",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "audio", "stt"]
						},
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "audio",
									"type": "file",
									"src": ""
								}
							]
						}
					}
				}
			]
		},
		{
			"name": "06 - Embeddings y Reranking",
			"item": [
				{
					"name": "Generate Embeddings",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/embeddings",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "embeddings"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"input\": [\n\t\t\"Laravel es un framework PHP.\",\n\t\t\"Django es un framework Python.\"\n\t]\n}"
						}
					}
				},
				{
					"name": "Vector Search",
				"request": {
					"method": "POST",
					"header": [
						{
							"key": "Accept",
							"value": "application/json"
						},
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"url": {
						"raw": "{{base_url_sdk_ai}}/agent/vector-search",
						"host": ["{{base_url_sdk_ai}}"],
						"path": ["agent", "vector-search"]
					},
					"body": {
						"mode": "raw",
						"raw": "{\n\t\"query\": \"how to define routes in Laravel\",\n\t\"limit\": 3\n}"
					}
				}
			},
			{
				"name": "Rerank Documents",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url_sdk_ai}}/agent/rerank",
							"host": ["{{base_url_sdk_ai}}"],
							"path": ["agent", "rerank"]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n\t\"query\": \"frameworks PHP\",\n\t\"documents\": [\n\t\t\"Django es un framework web de Python.\",\n\t\t\"Laravel es un framework de aplicaciones web en PHP.\",\n\t\t\"React es una biblioteca JavaScript para interfaces de usuario.\"\n\t]\n}"
						}
					}
				}
			]
		}
	]
}
